# Anthropic API key — used for live demand research via web search
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-opus-4-7

# Demand research cache directory (relative to repo root)
DEMAND_CACHE_DIR=.cache
DEMAND_CACHE_TTL_HOURS=24
# Frontend: use bundled JSON mocks until API routes exist (set to false for live /api/*)
NEXT_PUBLIC_USE_MOCKS=true
# When mocks are off, RSC uses fetch() — Node needs an absolute origin. Default: http://127.0.0.1:$PORT (PORT=3000).
# NEXT_INTERNAL_API_URL=http://localhost:3001

# OpenMeteo - free, no key required
OPENMETEO_BASE_URL=https://api.open-meteo.com/v1

# --- PagerDuty (UrbanFarm agents → Events API v2) ---
# Integration routing key from your Events API v2 integration (NOT the REST API token).
PAGERDUTY_ROUTING_KEY=
# Demo / CI: log incidents under .urbanfarm/pagerduty-mock.jsonl instead of calling PD.
PAGERDUTY_MOCK=true

# --- Optional: PagerDuty REST API token (e.g. Cursor Remote MCP `Authorization: Token token=…`) ---
# See https://pagerduty.github.io/pagerduty-mcp-server/docs/remote-server/setup
# Do NOT use this value as PAGERDUTY_ROUTING_KEY.
PAGERDUTY_API_KEY=

# --- Agent connectivity (offline queue) ---
# When true, triggers/resolves are appended to .urbanfarm/outbound-events.json only.
AGENT_OFFLINE=false
# Optional HEAD/GET probe; if unset, agents assume online.
# AGENT_CONNECTIVITY_URL=https://example.com

# Grid electricity cost (EUR per kWh)
ELECTRICITY_COST_EUR_KWH=0.25

# Solar installation cost per kWp (EUR)
SOLAR_COST_EUR_KWP=1200
